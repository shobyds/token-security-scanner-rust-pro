# TokenGuard Environment Variables
# Copy this file to .env and fill in your actual API keys

# ─────────────────────────────────────────────────────────────────────────────
# LLM API Configuration (REQUIRED)
# ─────────────────────────────────────────────────────────────────────────────
# Groq API (recommended for fast inference)
# Get your FREE API key from: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SECS=30

# HuggingFace Space (alternative - optional)
# HF_SPACE_URL=
# HF_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Blockchain Data APIs (REQUIRED)
# ─────────────────────────────────────────────────────────────────────────────
# Etherscan API (for Ethereum contract data)
# Get your FREE API key from: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# GoPlus Security API (FREE - no signup required)
# Get your API keys from: https://docs.gopluslabs.io/
API_KEY=
API_SECRET=

# Covalent API (for token holder data)
# Get your FREE API key from: https://www.covalenthq.com/platform/
COVALENT_API_KEY=

# Moralis API (for on-chain data)
# Get your FREE API key from: https://moralis.io/
MORALIS_API_KEY=

# Ethplorer API (optional - uses "freekey" by default)
# Get your API key from: https://ethplorer.io/
ETHPLORER_API_KEY=freekey

# BitQuery API (for on-chain analytics)
# Get your FREE API token from: https://bitquery.io/
BITQUERY_API_TOKEN=
BITQUERY_API_ENDPOINT=https://graphql.bitquery.io
BITQUERY_APPLICATION_ID=

# ─────────────────────────────────────────────────────────────────────────────
# RPC Endpoints (OPTIONAL - for direct blockchain interaction)
# ─────────────────────────────────────────────────────────────────────────────
# Ethereum Mainnet
RPC_ETHEREUM=
RPC_SEPOLIA=

# Layer 2s
RPC_BASE=
RPC_ARBITRUM=
RPC_OPTIMISM=

# Other chains
RPC_POLYGON=
RPC_BSC=https://bsc-dataseed.binance.org
RPC_AVALANCHE=https://api.avax.network/ext/bc/C/rpc
RPC_FANTOM=https://rpc.fantom.network

# ─────────────────────────────────────────────────────────────────────────────
# Application Settings
# ─────────────────────────────────────────────────────────────────────────────
# Database
DB_PATH=scans.db

# Server
BIND_ADDR=0.0.0.0
PORT=45890

# Cache
CACHE_REFRESH_SECONDS=600

# ─────────────────────────────────────────────────────────────────────────────
# DEX Router Addresses (for simulation)
# ─────────────────────────────────────────────────────────────────────────────
UNISWAP_V2_ROUTER=0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D
UNISWAP_V3_ROUTER=0xE592427A0AEce92De3Edee1F18E0157C05861564
SUSHISWAP_ROUTER=0xd9e1cE17f2641f24aE83637ab66a2cca9C227EF9
PANCAKESWAP_ROUTER=0x10ED43C718714eB6e425251224C88eFcF4203666

# ─────────────────────────────────────────────────────────────────────────────
# Chain IDs
# ─────────────────────────────────────────────────────────────────────────────
ETHEREUM_CHAIN_ID=1
SEPOLIA_CHAIN_ID=11155111
BASE_CHAIN_ID=8453
ARBITRUM_CHAIN_ID=42161
POLYGON_CHAIN_ID=137
OPTIMISM_CHAIN_ID=10
BSC_CHAIN_ID=56
AVALANCHE_CHAIN_ID=43114
FANTOM_CHAIN_ID=250
